SERVER_ADDR=:8080
APP_ORIGIN=http://localhost:5173

TRAQ_BASE_URL=https://q.trap.jp
TRAQ_CLIENT_ID=your-traq-oauth-client-id
TRAQ_REDIRECT_URL=http://localhost:5173/oauth/callback
OAUTH_SCOPE=read
TRAQ_BOT_ACCESS_TOKEN=your-traq-bot-access-token
