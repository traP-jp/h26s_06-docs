{
    "name": "h26s_06",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bun run check:type && vite build",
        "check": "bun run scripts/runChecks.ts check",
        "check:fix": "bun run scripts/runChecks.ts fix",
        "check:format": "prettier --check --cache .",
        "check:format:fix": "prettier --write --cache .",
        "check:lint": "eslint . --max-warnings 0 --cache",
        "check:lint:fix": "eslint . --fix --max-warnings 0 --cache",
        "check:type": "vue-tsc --build",
        "dev": "vite",
        "dev:build": "bun run --bun dev --build",
        "husky:prepare": "cd ../../ && husky .husky",
        "mock:down": "docker compose -f ../../mocks/server/docker-compose.yml down",
        "mock:up": "bun run scripts/setupMockEnv.ts && docker compose -f ../../mocks/server/docker-compose.yml up -d --build",
        "preview:build": "bun run --bun preview --build"
    },
    "overrides": {
        "@vue/compat": "beta",
        "@vue/compiler-core": "beta",
        "@vue/compiler-dom": "beta",
        "@vue/compiler-sfc": "beta",
        "@vue/compiler-ssr": "beta",
        "@vue/compiler-vapor": "beta",
        "@vue/reactivity": "beta",
        "@vue/runtime-core": "beta",
        "@vue/runtime-dom": "beta",
        "@vue/runtime-vapor": "beta",
        "@vue/server-renderer": "beta",
        "@vue/shared": "beta",
        "vue": "beta"
    },
    "dependencies": {
        "axios": "^1.18.1",
        "d3-force-3d": "^3.0.6",
        "three": "^0.185.0",
        "vue": "beta"
    },
    "devDependencies": {
        "@eslint/css": "^1.3.0",
        "@eslint/js": "^9.21.0",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@tsconfig/node24": "^24.0.4",
        "@types/bun": "^1.3",
        "@types/css-modules": "^1.0.5",
        "@types/glob": "^9.0.0",
        "@types/node": "^25.5.2",
        "@types/three": "^0.185.0",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsonc": "^3.2.0",
        "eslint-plugin-unicorn": "^65.0.1",
        "glob": "^13.0.6",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "npm-run-all2": "^9.0.2",
        "prettier": "^3.8.4",
        "typescript": "^6.0",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vue-tsc": "^3.3.5"
    },
    "engines": {
        "bun": ">=1.3.0",
        "node": ">=24.12.0"
    }
}
